<!--
  多机狗同场景 MJCF 文件
  包含 4 只 Go1，各自独立控制，共享同一地面

  每只狗的关节/执行器名称加了前缀（go0_, go1_, go2_, go3_）
  避免命名冲突
-->
<mujoco model="multi_go1 scene">
  <compiler angle="radian" meshdir="mujoco_menagerie/unitree_go1/assets" autolimits="true"/>
  <option cone="elliptic" impratio="100"/>

